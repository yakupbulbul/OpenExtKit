{
  "name": "@openextkit/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "openext": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @openextkit/templates build && pnpm build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@openextkit/core": "workspace:^",
    "@openextkit/manifest": "workspace:^",
    "@openextkit/packaging": "workspace:*",
    "@openextkit/testing": "workspace:*",
    "@openextkit/templates": "workspace:*",
    "cac": "^7.0.0"
  }
}
